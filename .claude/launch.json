{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "stalk-market",
      "runtimeExecutable": "/opt/homebrew/bin/node",
      "runtimeArgs": ["-e", "require('http').createServer((q,r)=>{const fs=require('fs'),p=require('path'),f=p.join('.',q.url==='/'?'/payments.html':q.url),e=p.extname(f),t={'.html':'text/html','.css':'text/css','.js':'text/javascript','.png':'image/png','.json':'application/json'};fs.readFile(f,(err,d)=>{if(err){r.writeHead(404);r.end('Not found')}else{r.writeHead(200,{'Content-Type':t[e]||'text/plain'});r.end(d)}})}).listen(8090)"],
      "port": 8090
    }
  ]
}
